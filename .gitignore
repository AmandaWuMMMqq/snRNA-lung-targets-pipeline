# R session artifacts
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# targets store (large, regenerated by pipeline)
_targets/

# Generated outputs (regenerated by pipeline)
outputs/rds/
outputs/plots/
outputs/tables/
outputs/audit/
outputs/logs/
outputs/reports/

# Large binary data files — never commit
*.rds
*.RDS
*.h5seurat
*.h5ad
*.loom
*.h5

# Mac metadata
.DS_Store

# Claude Code local settings (machine-specific)
.claude/

# renv cache (optional — keep renv.lock but not the library)
renv/library/
renv/local/
renv/lock/
renv/staging/

# Quarto render output
*_files/
*.quarto/

# Editor-specific
*.Rproj
.idea/
.vscode/

# Logs
*.log
